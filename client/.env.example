# Production API (no trailing slash). Vercel: set this to the Render URL below.
VITE_API_URL=https://beabr.onrender.com
# Optional: canonical origin for invite links / QR (defaults to window.location.origin if unset).
# Set on Vercel so shared links always use production even on preview URLs: https://beabr.vercel.app
# VITE_APP_ORIGIN=https://beabr.vercel.app
# Local dev: omit VITE_API_URL to use the Vite /api proxy (see vite.config.js), or use http://localhost:5000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
