DATABASE_URL=
# Legacy / unused by current API path (SPA uses Supabase Auth). Safe to omit.
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Canonical SPA origin (no trailing slash). CORS in production, share links from API, dev allowlist base.
CLIENT_URL=https://beabr.vercel.app
# Comma-separated extra dev origins beyond CLIENT_URL / localhost presets (NODE_ENV ≠ production).
# DEV_CORS_ORIGINS=http://192.168.1.50:5173
# Behind reverse proxy → rate limiting + logging see correct client IPs
# TRUST_PROXY=1
# RATE_LIMIT_PER_MIN=
# RATE_LIMIT_JOIN_PER_10M=

SERVER_URL=https://beabr.onrender.com

# Supabase Storage (for private pledge QR/receipt uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=beabr-pledges

# AES-256 key for group-pledge payout text + QR payloads (openssl rand -base64 32, or crypto.randomBytes(32).toString("base64")).
# REQUIRED for initiating/updating pledges once set in production — keep out of repos and rotate with a re-encryption plan.
BEABR_PLEDGE_ENCRYPTION_KEY=

# Supabase Auth (frontend uses anon key, backend verifies bearer tokens)
# Client env (set in client/.env):
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
